# Runtime mode
APP_ENV=local
LOCAL_BETA_MODE=true

# Required for AI features (chat/curriculum/ocr/rag extraction/embedding)
GEMINI_API_KEY=your_api_key_here

# Optional AI settings
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
API_TIMEOUT_SEC=30
API_MAX_RETRIES=2

# Authentication
# SESSION_SECRET: generate with `python -c "import secrets; print(secrets.token_hex(32))"`
SESSION_SECRET=change_this_to_a_random_secret
# ADMIN_PASSWORD_HASH: generate with the command shown in README
ADMIN_PASSWORD_HASH=

# -----------------------------------------------------------------
# Database: PostgreSQL + pgvector (推奨)
# Docker Compose 使用時は以下をそのまま利用可能
# -----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/math_teacher

# ローカル SQLite を使う場合 (pgvector / Docker 不要、RAG は Python フォールバック)
# DATABASE_URL=sqlite:///./data/math_teacher.db

# -----------------------------------------------------------------
# ストレージバックエンド: local | gcs
# -----------------------------------------------------------------
STORAGE_BACKEND=local

# Google Cloud Storage を使用する場合
# GCS_BUCKET_NAME=your-bucket-name
# GCS_CREDENTIALS_FILE=/path/to/service-account.json

# CORS (comma-separated)
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Upload constraints
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/png,image/jpeg,image/webp,image/gif